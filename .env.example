# Furtail Flutter App - optional environment variables
# Prefer using: flutter run --dart-define-from-file=env/dev.json
# This file is provided for consistency with the delivery rule.

API_BASE_URL=http://192.168.10.108:7200/api/v1
# API_HOST is also supported (same meaning as API_BASE_URL)
API_HOST=

REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379

VIDEO_PROCESSING_ENABLED=true
VIDEO_MAX_UPLOAD_MB=100
VIDEO_KEEP_ORIGINAL=false
VIDEO_TARGET_HEIGHT=720
VIDEO_TARGET_CRF=28
VIDEO_QUEUE_CONCURRENCY=1